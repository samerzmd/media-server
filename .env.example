# Copy this file to .env and replace the placeholder values with actual secrets

# Telegram Bot Token (Get it from BotFather in Telegram)
BOT_TOKEN=your_telegram_bot_token

# Radarr API Key (Found in Radarr settings under "API Key")
RADARR_API_KEY=your_radarr_api_key

# Sonarr API Key (Found in Sonarr settings under "API Key")
SONARR_API_KEY=your_sonarr_api_key

# Prowlarr API Key (Found in Prowlarr settings under "API Key")
PROWLARR_API_KEY=your_prowlarr_api_key

# SubGen data directory (models cache + subgen.env)
subgenai_data_folder=./subgen

# --- recommendarr (Jellyfin -> TMDB -> Radarr/Sonarr recommender) ---
# Jellyfin API key (Jellyfin Dashboard -> Advanced -> API Keys -> +)
JELLYFIN_API_KEY=your_jellyfin_api_key
# Optional: limit to specific Jellyfin user IDs, comma-separated. Empty = all users.
JELLYFIN_USER_IDS=
# TMDB API key (https://www.themoviedb.org/settings/api -> API Key v3 auth)
TMDB_API_KEY=your_tmdb_api_key
# recommendarr dashboard login (CHANGE THESE)
RECOMMENDARR_USER=admin
RECOMMENDARR_PASSWORD=change_me_please
# Optional: fixed Flask session key (leave blank to auto-generate in /data)
RECOMMENDARR_SECRET_KEY=
